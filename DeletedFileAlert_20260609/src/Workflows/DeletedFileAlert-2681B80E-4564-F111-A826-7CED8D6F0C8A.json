            "parameters": {
              "emailMessage/To": "gregg.barker@flowaiibbq.com",
              "emailMessage/Subject": "@{triggerOutputs()?['body/FileNameWithExtension']} Deleted by @{triggerOutputs()?['body/DeletedByUserName']}",
